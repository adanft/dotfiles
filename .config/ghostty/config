palette = 0=#45475a
palette = 1=#f38ba8
palette = 2=#a6e3a1
palette = 3=#f9e2af
palette = 4=#89b4fa
palette = 5=#f5c2e7
palette = 6=#94e2d5
palette = 7=#a6adc8
palette = 8=#585b70
palette = 9=#f38ba8
palette = 10=#a6e3a1
palette = 11=#f9e2af
palette = 12=#89b4fa
palette = 13=#f5c2e7
palette = 14=#94e2d5
palette = 15=#bac2de
background = #1e1e2e
foreground = #cdd6f4
cursor-color = #c8d3f5
cursor-text = #1e1e2e
selection-background = #353749
selection-foreground = #cdd6f4

font-family = Iosevka Nerd Font Propo
font-size = 12

background-opacity = 1

window-decoration = false
window-theme = ghostty
window-padding-x = 0
window-padding-y = 0
confirm-close-surface = true
window-show-tab-bar = never
window-padding-balance = true
adjust-cursor-thickness = 1

# Disable adjust selection
keybind = shift+up=unbind
keybind = shift+down=unbind
keybind = shift+right=unbind
keybind = shift+insert=unbind
keybind = shift+left=unbind

# Disable scroll move
keybind = shift+page_up=unbind
keybind = shift+end=unbind
keybind = shift+page_down=unbind
keybind = shift+home=unbind

# Disable default split keys
keybind = ctrl+shift+o=open_config
keybind = ctrl+shift+e=unbind
keybind = super+ctrl+left_bracket=unbind
keybind = super+ctrl+right_bracket=unbind
keybind = ctrl+alt+down=unbind
keybind = ctrl+alt+up=unbind

# Disable default tab keys
keybind = alt+one=unbind
keybind = alt+two=unbind
keybind = alt+three=unbind
keybind = alt+four=unbind
keybind = alt+five=unbind
keybind = alt+six=unbind
keybind = alt+seven=unbind
keybind = alt+eight=unbind
keybind = alt+nine=unbind
keybind = ctrl+page_down=unbind
keybind = ctrl+shift+left=unbind
keybind = ctrl+page_up=unbind
keybind = ctrl+tab=unbind
keybind = ctrl+shift+right=unbind
keybind = ctrl+shift+t=unbind
keybind = ctrl+shift+tab=unbind

# Font size (only =, -, 0)
keybind = ctrl+equal=increase_font_size:1
keybind = ctrl+-=decrease_font_size:1
keybind = ctrl+0=reset_font_size
keybind = ctrl+plus=unbind

# Disable close windows keys
keybind = alt+f4=unbind

# Disable some repeat keys
keybind = ctrl+comma=unbind
keybind = ctrl+insert=unbind
keybind = ctrl+alt+shift+j=unbind
keybind = ctrl+alt+shift+comma=unbind
keybind = ctrl+shift+page_up=unbind
keybind = ctrl+shift+page_down=unbind
keybind = ctrl+shift+,=unbind
keybind = ctrl+shift+p=unbind
keybind = ctrl+shift+q=unbind
keybind = ctrl+shift+n=unbind
keybind = ctrl+shift+i=unbind
keybind = ctrl+shift+a=unbind
keybind = ctrl+enter=unbind
keybind = ctrl+,=unbind

# Key configurations
keybind = ctrl+shift+r=reload_config
keybind = ctrl+shift+n=new_tab
keybind = ctrl+shift+l=new_split:right
keybind = ctrl+shift+j=new_split:down
keybind = ctrl+shift+k=new_split:up
keybind = ctrl+shift+h=new_split:left
keybind = ctrl+shift+w=close_tab
keybind = ctrl+down=scroll_page_down
keybind = ctrl+up=scroll_page_up

# Disable existens keys
keybind = ctrl+shift+l=unbind
keybind = ctrl+shift+j=unbind
keybind = ctrl+shift+k=unbind
keybind = ctrl+shift+h=unbind
keybind = ctrl+shift+w=close_tab
keybind = ctrl+down=unbind
keybind = ctrl+up=unbind
keybind = ctrl+shift+enter=unbind
keybind = ctrl+alt+right=unbind
keybind = ctrl+alt+left=unbind
keybind = super+ctrl+shift+equal=unbind
keybind = super+ctrl+shift+up=unbind
keybind = super+ctrl+shift+down=unbind
keybind = super+ctrl+shift+right=unbind
keybind = super+ctrl+shift+left=unbind
keybind = super+ctrl+shift+plus=unbind
keybind = super+ctrl+shift+j=unbind

# Tab navigation (only 1-4)
keybind = alt+digit_1=goto_tab:1
keybind = alt+digit_2=goto_tab:2
keybind = alt+digit_3=goto_tab:3
keybind = alt+digit_4=goto_tab:4
keybind = alt+digit_5=unbind
keybind = alt+digit_6=unbind
keybind = alt+digit_7=unbind
keybind = alt+digit_8=unbind
keybind = alt+digit_9=unbind

# configurations
split-divider-color=white
unfocused-split-fill=#1e1e2e
unfocused-split-opacity=0.5
gtk-single-instance=true
