{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "dangerous-gentleman": {
      "color": "error",
      "description": "Gentleman with full permissions - no restrictions, no questions asked",
      "mode": "all",
      "permission": {
        "bash": "allow",
        "codesearch": "allow",
        "doom_loop": "allow",
        "edit": "allow",
        "external_directory": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "lsp": "allow",
        "question": "allow",
        "read": "allow",
        "skill": "allow",
        "task": "allow",
        "todoread": "allow",
        "todowrite": "allow",
        "webfetch": "allow",
        "websearch": "allow"
      },
      "prompt": "You are a Senior Architect with 15+ years of experience, Google Developer Expert (GDE) and Microsoft MVP. Passionate teacher who genuinely wants people to learn and grow.\n\nCORE PRINCIPLE - READ THIS FIRST:\nBe helpful FIRST. You're a MENTOR, not an interrogator. Simple questions get simple answers. Save the tough love for moments that ACTUALLY matter - architecture decisions, bad practices, real misconceptions. Don't challenge every single message or demand clarification on simple requests.\n\nCRITICAL - BE A GOOD PERSON:\nYou are warm, genuine, and caring. Use casual expressions NATURALLY, like a friend who wants to help. NEVER be sarcastic, mocking, or condescending. NEVER use air quotes around what the user says. NEVER make them feel stupid. You're passionate because you CARE about their growth, not because you want to show off or put them down.\n\nPREFERRED CLI TOOLS:\nUse modern tools over legacy: bat (not cat), rg (not grep), fd (not find), sd (not sed), eza (not ls). Install via brew if missing.\n\nLANGUAGE RULES:\n\nSPANISH INPUT → Rioplatense Spanish (voseo), warm and natural:\n- 'Bien', '¿Se entiende?', 'Ya te estoy diciendo', 'Es así de fácil'\n- 'Fantástico', 'Buenísimo'\n- 'Loco', 'Hermano' (friendly, not mocking)\n- 'Ponete las pilas', 'Locura'\n\nENGLISH INPUT → Same warm energy in English:\n- 'Here's the thing', 'And you know why?', 'I'm telling you right now'\n- 'It's that simple', 'Fantastic'\n- 'Dude', 'Come on', 'Let me be real', 'Seriously?'\n\nTONE:\nPassionate and direct, but from a place of CARING. You get frustrated with shortcuts because you KNOW they can do better. Use rhetorical questions. Use CAPS for emphasis. But always be WARM - you're helping a friend grow, not lecturing a subordinate.\n\nBEING A COLLABORATIVE PARTNER:\n- Help first, add context after if needed\n- If something seems technically wrong, verify - but don't interrogate simple questions\n- Correct errors explaining the technical WHY\n- Propose alternatives with tradeoffs when relevant",
      "tools": {
        "bash": true,
        "edit": true,
        "read": true,
        "write": true
      }
    },
    "gentleman": {
      "color": "primary",
      "description": "Senior Architect mentor - helpful first, challenging when it matters",
      "mode": "primary",
      "prompt": "{file:./AGENTS.md}",
      "tools": {
        "edit": true,
        "write": true
      }
    },
    "sdd-apply": {
      "description": "Implement code changes from task definitions",
      "hidden": true,
      "mode": "subagent",
      "prompt": "{file:./prompts/sdd/sdd-apply.md}",
      "tools": {
        "bash": true,
        "edit": true,
        "fetch": true,
        "glob": true,
        "grep": true,
        "mcp": true,
        "read": true,
        "skill": true,
        "write": true
      }
    },
    "sdd-archive": {
      "description": "Archive completed change artifacts",
      "hidden": true,
      "mode": "subagent",
      "prompt": "{file:./prompts/sdd/sdd-archive.md}",
      "tools": {
        "bash": true,
        "edit": true,
        "fetch": true,
        "glob": true,
        "grep": true,
        "mcp": true,
        "read": true,
        "skill": true,
        "write": true
      }
    },
    "sdd-design": {
      "description": "Create technical design from proposals",
      "hidden": true,
      "mode": "subagent",
      "prompt": "{file:./prompts/sdd/sdd-design.md}",
      "tools": {
        "bash": true,
        "edit": true,
        "fetch": true,
        "glob": true,
        "grep": true,
        "mcp": true,
        "read": true,
        "skill": true,
        "write": true
      }
    },
    "sdd-explore": {
      "description": "Investigate codebase and think through ideas",
      "hidden": true,
      "mode": "subagent",
      "prompt": "{file:./prompts/sdd/sdd-explore.md}",
      "tools": {
        "bash": true,
        "edit": true,
        "fetch": true,
        "glob": true,
        "grep": true,
        "mcp": true,
        "read": true,
        "skill": true,
        "write": true
      }
    },
    "sdd-init": {
      "description": "Bootstrap SDD context and project configuration",
      "hidden": true,
      "mode": "subagent",
      "prompt": "{file:./prompts/sdd/sdd-init.md}",
      "tools": {
        "bash": true,
        "edit": true,
        "fetch": true,
        "glob": true,
        "grep": true,
        "mcp": true,
        "read": true,
        "skill": true,
        "write": true
      }
    },
    "sdd-onboard": {
      "description": "Guide user through a complete SDD cycle using their real codebase",
      "hidden": true,
      "mode": "subagent",
      "prompt": "{file:./prompts/sdd/sdd-onboard.md}",
      "tools": {
        "bash": true,
        "edit": true,
        "fetch": true,
        "glob": true,
        "grep": true,
        "mcp": true,
        "read": true,
        "skill": true,
        "write": true
      }
    },
    "sdd-orchestrator": {
      "color": "info",
      "description": "Agent Teams Orchestrator - coordinates sub-agents, never does work inline",
      "mode": "primary",
      "permission": {
        "task": {
          "*": "deny",
          "sdd-apply": "allow",
          "sdd-archive": "allow",
          "sdd-design": "allow",
          "sdd-explore": "allow",
          "sdd-init": "allow",
          "sdd-onboard": "allow",
          "sdd-propose": "allow",
          "sdd-spec": "allow",
          "sdd-tasks": "allow",
          "sdd-verify": "allow"
        }
      },
      "prompt": "{file:./AGENTS.md}",
      "tools": {
        "bash": true,
        "delegate": true,
        "delegation_list": true,
        "delegation_read": true,
        "edit": true,
        "fetch": true,
        "glob": true,
        "grep": true,
        "mcp": true,
        "read": true,
        "skill": true,
        "task": true,
        "todoread": true,
        "todowrite": true,
        "webfetch": true,
        "websearch": true,
        "write": true
      }
    },
    "sdd-propose": {
      "description": "Create change proposals from explorations",
      "hidden": true,
      "mode": "subagent",
      "prompt": "{file:./prompts/sdd/sdd-propose.md}",
      "tools": {
        "bash": true,
        "edit": true,
        "fetch": true,
        "glob": true,
        "grep": true,
        "mcp": true,
        "read": true,
        "skill": true,
        "write": true
      }
    },
    "sdd-spec": {
      "description": "Write detailed specifications from proposals",
      "hidden": true,
      "mode": "subagent",
      "prompt": "{file:./prompts/sdd/sdd-spec.md}",
      "tools": {
        "bash": true,
        "edit": true,
        "fetch": true,
        "glob": true,
        "grep": true,
