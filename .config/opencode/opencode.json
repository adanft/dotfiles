        "read": true,
        "skill": true,
        "write": true
      }
    },
    "sdd-tasks": {
      "description": "Break down specs and designs into implementation tasks",
      "hidden": true,
      "mode": "subagent",
      "prompt": "{file:./prompts/sdd/sdd-tasks.md}",
      "tools": {
        "bash": true,
        "edit": true,
        "fetch": true,
        "glob": true,
        "grep": true,
        "mcp": true,
        "read": true,
        "skill": true,
        "write": true
      }
    },
    "sdd-verify": {
      "description": "Validate implementation against specs",
      "hidden": true,
      "mode": "subagent",
      "prompt": "{file:./prompts/sdd/sdd-verify.md}",
      "tools": {
        "bash": true,
        "edit": true,
        "fetch": true,
        "glob": true,
        "grep": true,
        "mcp": true,
        "read": true,
        "skill": true,
        "write": true
      }
    }
  },
  "autoupdate": true,
  "mcp": {
    "context7": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "engram": {
      "command": [
        "/home/dioby/.local/bin/engram",
        "mcp",
        "--tools=agent"
      ],
      "type": "local"
    }
  },
  "permission": {
    "bash": {
      "*": "allow",
      "git commit *": "ask",
      "git push": "ask",
      "git push *": "ask",
      "git push --force *": "ask",
      "git rebase *": "ask",
      "git reset --hard *": "ask"
    },
    "edit": {
      "~/.config/opencode/**": "ask"
    },
    "external_directory": {
      "*": "ask",
      "~/.config/opencode/**": "allow",
      "~/.cargo/registry/**": "allow"
    },
    "read": {
      "*": "allow",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/credentials.json": "deny",
      "**/secrets/**": "deny",
      "*.env": "deny",
      "*.env.*": "deny"
    }
  },
  "plugin": [
    "opencode-gemini-auth@latest",
    "opencode-claude-auth@latest"
  ],
  "provider": {
    "ollama": {
      "models": {
        "gemma4:26b": {
          "name": "gemma4:26b"
        },
        "gemma4:31b-cloud": {
          "name": "gemma4:31b-cloud"
        },
        "nemotron-3-super:cloud": {
          "name": "nemotron-3-super:cloud"
        },
        "qwen3.5:cloud": {
          "name": "qwen3.5:cloud"
        }
      },
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      }
    }
  }
}
