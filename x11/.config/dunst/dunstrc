[global]
    follow = mouse
    vertical_alignment = top
    origin = top-right
    show_indicators = true
    dmenu = /home/dioby/.config/rofi/scripts/dunst-context.sh
    mouse_left_click = context
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_current
    offset = (2, 30)
    margin = 10
    spacing = 10
    gap_size = 6
    font = IosevkaTerm Nerd Font 12
    format = "<b>%s</b>\n%b"
    alignment = left
    word_wrap = true
    ellipsize = middle
    ignore_newline = false
    stack_duplicates = true
    hide_duplicate_count = false
    show_age_threshold = 0
    always_run_script = true
    icon_position = left
    min_icon_size = 32
    max_icon_size = 42
    enable_recursive_icon_lookup = true
    icon_theme = candy-icons, Qogir-Dark, Papirus-Dark
    corner_radius = 6
    sort = id
    frame_color = "#89b4fa"
    frame_width = 1
    highlight = "#89b4fa"
[urgency_low]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    timeout = 10

[urgency_normal]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    timeout = 10

[urgency_critical]
    background = "#1e1e2e"
    foreground = "#f38ba8"
    frame_color = "#fab387"
    timeout = 0
